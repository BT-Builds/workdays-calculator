{
  "info": {
    "name": "workdays-calculator API",
    "description": "Calculate business days between two dates, excluding weekends and holidays",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://workdays-calculator.vercel.app",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "free-demo-key",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "Calculate Workdays",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/calculate",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "calculate"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"start_date\": \"\",\n  \"end_date\": \"\",\n  \"weekend_days\": \"\",\n  \"country_code\": \"\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    }
  ]
}